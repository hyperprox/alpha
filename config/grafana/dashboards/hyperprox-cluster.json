{
  "uid": "hyperprox-cluster",
  "title": "HyperProx \u2014 Cluster Overview",
  "tags": [
    "hyperprox"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU Usage \u2014 All Nodes",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "100 - (avg by(node) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{node}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Memory Usage \u2014 All Nodes",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "{{node}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Network I/O \u2014 All Nodes",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(node_network_receive_bytes_total{device=\"vmbr0\"}[5m])",
          "legendFormat": "{{node}} \u2193"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(node_network_transmit_bytes_total{device=\"vmbr0\"}[5m])",
          "legendFormat": "{{node}} \u2191"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "binBps"
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "CEPH Pool Usage",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "(ceph_pool_bytes_used / (ceph_pool_bytes_used + ceph_pool_max_avail)) * 100",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "GPU \u2014 VRAM Usage",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "nvidia_smi_memory_used_bytes / 1024 / 1024 / 1024",
          "legendFormat": "{{node}} Used (GB)"
        },
        {
          "datasource": "Prometheus",
          "expr": "nvidia_smi_memory_free_bytes / 1024 / 1024 / 1024",
          "legendFormat": "{{node}} Free (GB)"
        },
        {
          "datasource": "Prometheus",
          "expr": "nvidia_smi_memory_total_bytes / 1024 / 1024 / 1024",
          "legendFormat": "{{node}} Total (GB)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "GPU \u2014 Utilization & Temperature",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "nvidia_smi_utilization_gpu_ratio * 100",
          "legendFormat": "{{node}} Utilization %"
        },
        {
          "datasource": "Prometheus",
          "expr": "nvidia_smi_temperature_gpu",
          "legendFormat": "{{node}} Temperature \u00b0C"
        },
        {
          "datasource": "Prometheus",
          "expr": "nvidia_smi_power_draw_watts",
          "legendFormat": "{{node}} Power Draw (W)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Disk Usage \u2014 Root Filesystem",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}) * 100",
          "legendFormat": "{{node}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Intel GPU \u2014 Engine Utilization",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "intel_gpu_top_engines_busy_percent",
          "legendFormat": "{{node}} {{engine}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Intel GPU \u2014 Memory Bandwidth",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 32
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "intel_gpu_top_memory_bandwidth_bytes_per_second",
          "legendFormat": "{{node}} {{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "binBps"
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Intel GPU \u2014 Power Draw",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 40
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "intel_gpu_top_power_watts",
          "legendFormat": "{{node}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt"
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Intel GPU \u2014 Frequency",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 40
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "intel_gpu_top_frequency_mhz",
          "legendFormat": "{{node}} {{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "megahertz"
        }
      }
    }
  ]
}